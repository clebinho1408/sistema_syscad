# SysCad - Arquivo de Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores

# ===========================================
# BANCO DE DADOS (OBRIGATÓRIO)
# ===========================================
# URL de conexão PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_banco
DATABASE_URL=postgresql://usuario:senha@localhost:5432/syscad

# ===========================================
# SEGURANÇA (RECOMENDADO ALTERAR)
# ===========================================
# Chave secreta para sessões (gere uma chave aleatória segura)
# Use: openssl rand -hex 32
SESSION_SECRET=sua_chave_secreta_aqui_mude_em_producao

# ===========================================
# ARMAZENAMENTO DE ARQUIVOS
# ===========================================
# Caminho para armazenamento local de arquivos (padrão: ./uploads)
# Os documentos enviados serão salvos neste diretório
LOCAL_STORAGE_PATH=./uploads

# ===========================================
# IA / OCR (OPCIONAL)
# ===========================================
# Chave da API Google Gemini para OCR e análise de documentos
# Obtenha em: https://aistudio.google.com/apikey
# Deixe em branco para desabilitar OCR
GEMINI_API_KEY=

# ===========================================
# SERVIDOR (PRODUÇÃO)
# ===========================================
# Porta do servidor (padrão: 5000)
PORT=5000

# Ambiente de execução
NODE_ENV=production

# ===========================================
# VARIÁVEIS ESPECÍFICAS DO REPLIT (IGNORAR EM VPS)
# ===========================================
# Essas variáveis são configuradas automaticamente no Replit
# NÃO configure em ambiente VPS
# REPL_ID=
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
